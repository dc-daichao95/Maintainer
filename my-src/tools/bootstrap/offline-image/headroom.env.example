# Headroom 容器运行配置（被 load_run.sh 自动读取）。
# 用法：复制为 headroom.env 并按现场修改，然后运行 ./load_run.sh。
#   cp headroom.env.example headroom.env

# 【必填】上游 OpenAI 兼容 LLM 的 base 地址。
#   - 不要带 /v1，Headroom 会自动拼接 /v1/chat/completions。
#   - 应填 Maintainer 接入 Headroom 之前原本直连的那台 LLM 地址。
#   - 容器必须能访问到它（见下方 HEADROOM_NETWORK）。
OPENAI_TARGET_API_URL=http://10.0.0.5:8000

# 【可选】docker 网络模式。
#   若上游 LLM 只有“宿主机”能访问、默认 bridge 网络的容器访问不到，设为 host
#   让容器共享宿主机网络（此时端口映射 -p 省略，proxy 直接在宿主机 127.0.0.1:8787 监听）。
#HEADROOM_NETWORK=host

# 【可选】代理端口（默认 8787）。
#HEADROOM_PORT=8787

# 【可选】容器名（默认 headroom）。
#HEADROOM_CONTAINER=headroom
